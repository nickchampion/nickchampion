{
  "include": ["apps/**/*.ts", "apps/**/*.vue", "components/**/*.ts", "integrations/**/*.ts", "*.d.ts", ".nodevault/build/schemas.ts"],
  "exclude": ["node_modules", "**/node_modules/*", ".nuxt", ".output", "**/.output/*", "dist", "**/.nuxt/*"],
  "compileOnSave": true,
  "typeRoots": ["./node_modules/@types"],
  "compilerOptions": {
    "types": ["node", "vitest/globals", "vite/client", "@nuxt/types", "@pinia/nuxt"],
    "allowJs": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./.platform/.tsbuildinfo",
    "target": "ES2022",
    "module": "preserve",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": false,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "lib": ["ES2022", "dom", "dom.iterable", "webworker"],
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "moduleResolution": "Bundler",
    "useDefineForClassFields": true,
    "noImplicitThis": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@platform/components.api": ["./components/api/index.ts"],
      "@platform/components.configuration": ["./components/configuration/index.ts"],
      "@platform/components.ravendb": ["./components/ravendb/index.ts"],
      "@platform/components.search": ["./components/search/index.ts"],
      "@platform/components.contracts": ["./components/contracts/index.ts"],
      "@platform/components.context": ["./components/context/index.ts"],
      "@platform/components.utils": ["./components/utils/index.ts"],
      "@platform/components.utils.server": ["./components/utils-server/index.ts"],
      "@platform/integrations.resend": ["./integrations/resend/index.ts"],
      "@platform/integrations.cloudflare": ["./integrations/cloudflare/index.ts"],
      "@platform/integrations.strapi": ["./integrations/strapi/index.ts"]
    }
  }
}
